<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>SUKLA</title>
  <style>
    body {
      margin: 0;
      background: #0b0b0b;
      color: #d4af37;
      font-family: Arial, sans-serif;
      display: flex;
      justify-content: center;
      align-items: center;
      height: 100vh;
    }

    .container {
      text-align: center;
    }

    h1 {
      font-size: 60px;
      letter-spacing: 10px;
      margin-bottom: 20px;
    }

    button {
      padding: 12px 30px;
      font-size: 16px;
      border: none;
      border-radius: 25px;
      background: #d4af37;
      color: #000;
      cursor: pointer;
      transition: 0.3s;
    }

    button:hover {
      background: #f5d76e;
    }
  </style>
</head>
<body>

  <div class="container">
    <h1>SUKLA</h1>
    <button onclick="alert('Coming Soon 🔥')">ENTER</button>
  </div>

</body>
</html>
